{
  // ── rust-analyzer ─────────────────────────────────────────────────────────
  // The Cargo project lives in rust/, not the workspace root.
  "rust-analyzer.linkedProjects": ["rust/Cargo.toml"],
  // Analyse the `mb` backend too, otherwise mb.rs shows up as dead code.
  "rust-analyzer.cargo.features": ["mb"],
  // On save, run clippy with -D warnings so editor markers match CI.
  "rust-analyzer.check.command": "clippy",
  "rust-analyzer.check.extraArgs": [
    "--all-targets",
    "--features", "mb",
    "--",
    "-D", "warnings"
  ],
  "rust-analyzer.cargo.targetDir": true,

  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
    "editor.formatOnSave": true,
    "editor.tabSize": 4
  },

  // ── Python ────────────────────────────────────────────────────────────────
  // Tests live in python/tests; pytest config is in python/pyproject.toml.
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.cwd": "${workspaceFolder}/python",
  "python.testing.pytestArgs": ["tests"],
  "python.analysis.extraPaths": ["python"],
  // Pin interpreter to the venv built by python/setup-analysis-env.sh —
  // ipykernel + matplotlib/pandas live here, so the notebook just works.
  "python.defaultInterpreterPath": "${workspaceFolder}/python/.venv/bin/python",
  "python.venvFolders": ["python", "."],
  "python.venvPath": "${workspaceFolder}/python",

  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  },
  // ruff also handles ipynb cells natively
  "notebook.formatOnSave.enabled": true,
  "notebook.codeActionsOnSave": {
    "notebook.source.fixAll.ruff": "explicit",
    "notebook.source.organizeImports.ruff": "explicit"
  },

  // ── Notebooks ─────────────────────────────────────────────────────────────
  "jupyter.notebookFileRoot": "${workspaceFolder}",
  "jupyter.kernels.trusted": [
    "${workspaceFolder}/python/.venv/share/jupyter/kernels/python3/kernel.json",
    "${env:HOME}/.local/share/jupyter/kernels/pow-analysis/kernel.json"
  ],
  "notebook.output.scrolling": true,
  // Honour the kernelspec.name field embedded in *.ipynb instead of forcing
  // the most-recently-used environment.
  "jupyter.useLegacyKernelDetection": false,

  // ── TOML / YAML / Markdown ────────────────────────────────────────────────
  "[toml]":     { "editor.defaultFormatter": "tamasfe.even-better-toml" },
  "[yaml]":     { "editor.defaultFormatter": "redhat.vscode-yaml" },
  "[markdown]": { "editor.wordWrap": "on", "files.trimTrailingWhitespace": false },

  // ── C (src/pow_mb.c) ──────────────────────────────────────────────────────
  // clangd picks up compile_commands.json if you set CARGO_TARGET_DIR and
  // run `bear -- cargo build --features mb`. Otherwise relies on .clangd
  // hints (committed at rust/src/.clangd).
  "[c]": {
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
  },

  // ── Files / search ────────────────────────────────────────────────────────
  "files.associations": {
    "Cargo.lock": "toml",
    "rust-toolchain.toml": "toml"
  },
  "files.exclude": {
    "**/target": true,
    "**/__pycache__": true,
    "**/.ipynb_checkpoints": true,
    "**/.pytest_cache": true
  },
  "search.exclude": {
    "**/target": true,
    "**/results": true,
    "**/Cargo.lock": true,
    "**/uv.lock": true,
    "**/.ipynb_checkpoints": true
  },
  "files.watcherExclude": {
    "**/target/**": true,
    "**/results/**": true
  },

  // ── Editor defaults ───────────────────────────────────────────────────────
  "editor.rulers": [100],
  "editor.renderWhitespace": "trailing",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,

  // ── Shell ─────────────────────────────────────────────────────────────────
  "shellcheck.enable": true,
  "[shellscript]": {
    "editor.defaultFormatter": "foxundermoon.shell-format",
    "editor.tabSize": 2
  }
}
