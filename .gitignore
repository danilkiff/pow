# Caches (Rust, Python)
.*_cache

# Python
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info
.pytest_cache/
.venv/

# Rust
target/
Cargo.lock

# Benchmark results: checked-in bench-*.json files under results/ are the
# reference baseline. repro.sh also writes env-*.txt snapshots; commit those
# deliberately when they are part of a published run. Local scratch copies are
# ignored (use *.json.bak as the conventional suffix).
*.json.bak

# Jupyter
.ipynb_checkpoints/
# nbconvert exports — .ipynb is the source of truth; GitHub renders it natively.
analysis/*.html
analysis/*.pdf
# jupyter-collaboration / yjs runtime state created when jupyter.sh runs.
.jupyter/
.jupyter_ystore.db

# Editor / OS
.DS_Store
*.swp
.vscode/
.idea/

# Per-user agent configs
.claude/
